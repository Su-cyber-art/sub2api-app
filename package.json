{
  "name": "sub2api-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "concurrently -n proxy,web -c green,blue \"npm run proxy\" \"npm run web:client\"",
    "web:client": "expo start --web",
    "typecheck": "tsc --noEmit",
    "proxy": "node server/index.js",
    "dev:web-proxy": "npm run web",
    "eas:build:development": "eas build --profile development",
    "eas:build:preview": "eas build --profile preview",
    "eas:build:production": "eas build --profile production",
    "eas:update:preview": "eas update --branch preview --message",
    "eas:update:production": "eas update --branch production --message",
    "start:dev-client": "expo start --dev-client",
    "eas:build:development:android": "eas build -p android --profile development",
    "eas:build:development:ios": "eas build -p ios --profile development",
    "eas:build:development:ios:device": "eas build -p ios --profile development-device"
  },
  "dependencies": {
    "@expo/ui": "~56.0.22",
    "@expo/vector-icons": "^15.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.21",
    "cors": "^2.8.6",
    "expo": "^56.0.16",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.21",
    "expo-dev-client": "~56.0.23",
    "expo-font": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-linking": "~56.0.15",
    "expo-router": "~56.2.15",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.13",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "~56.0.22",
    "express": "^5.2.1",
    "lucide-react-native": "^0.577.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "tailwindcss": "^4.2.1",
    "uniwind": "^1.3.2",
    "valtio": "^2.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "concurrently": "^9.2.1",
    "typescript": "~6.0.3"
  },
  "private": true
}
